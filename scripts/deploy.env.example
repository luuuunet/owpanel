# Copy to scripts/deploy.env and fill in your server details.
# Used by: scripts/auto-setup.sh deploy | scripts/auto-setup.ps1 -Deploy | scripts/deploy.py

DEPLOY_HOST=your-server-ip
DEPLOY_USER=root
# Use SSH key (recommended) OR password — not both required
DEPLOY_KEY=~/.ssh/id_rsa
# DEPLOY_PASSWORD=

OPEN_PANEL_PORT=8888
INSTALL_DIR=/opt/open-panel

# Optional: linux target arch for cross-compile (amd64 | arm64)
DEPLOY_GOARCH=amd64
